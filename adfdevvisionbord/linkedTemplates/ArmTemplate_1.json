	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "adfdevvisionbord"
		},
		"LS_restapi_parquet_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_restapi_parquet'"
		},
		"lscsvadls_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'lscsvadls'"
		},
		"lsexcelparqet_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'lsexcelparqet'"
		},
		"lsfilteradls1_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'lsfilteradls1'"
		},
		"lstxtadls_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'lstxtadls'"
		},
		"LS_restapi_parquet_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdevvisionboard.dfs.core.windows.net/"
		},
		"lscsvadls_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdevvisionboard.dfs.core.windows.net/"
		},
		"lsexcelparqet_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdevvisionboard.dfs.core.windows.net/"
		},
		"lsfilteradls1_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdevvisionboard.dfs.core.windows.net/"
		},
		"lstxtadls_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://adlsdevvisionboard.dfs.core.windows.net/"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
